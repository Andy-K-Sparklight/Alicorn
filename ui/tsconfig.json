{
    "compilerOptions": {
        "target": "ES2016",
        "module": "CommonJS",
        "allowJs": true,
        "jsx": "react-jsx",
        "jsxImportSource": "preact",
        "strict": true,
        "moduleResolution": "Node",
        "resolveJsonModule": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "baseUrl": "./",
        "paths": {
            "react": [
                "./node_modules/preact/compat/"
            ],
            "react/jsx-runtime": [
                "./node_modules/preact/jsx-runtime"
            ],
            "react-dom": [
                "./node_modules/preact/compat/"
            ],
            "react-dom/*": [
                "./node_modules/preact/compat/*"
            ]
        }
    },
    "include": [
        "./src/**/*"
    ]
}
